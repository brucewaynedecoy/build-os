# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
#
# Pattern quick reference:
#   foo         → matches "foo" at ANY depth (file or directory)
#   foo/        → matches directory "foo" at any depth
#   /foo        → matches "foo" ONLY at repo root
#   *.ext       → matches files at any depth
#   **/foo      → explicit "any depth" (same as bare `foo`)
#   !foo        → un-ignore (negation)
#
# IMPORTANT: .gitignore does NOT untrack files that are already committed.
# To untrack: `git rm --cached <path>` then commit.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# build outputs
dist/
build/
out/
wheels/
*.tsbuildinfo
next-env.d.ts

# testing
coverage/
tests/input/
tests/output/
test-results/
.playwright/

# environment files
.env
.env.*
!.env.example
!.env.test

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# scratch / backups / deprecated
.old/
.deprecated/
.backup/
.temp/
.tmp/
.templates/

# OS junk
.DS_Store
Thumbs.db

# secrets / certs
*.pem

# editor & tooling
.vscode/
.hintrc
.windsurfrules

# tool caches
.turbo/
.cache/
.parcel-cache/

# deployment platforms
.vercel/
.motia/

# python
__pycache__/
*.py[oc]
*.egg-info/
.venv/
venv/
python_modules/
